{
  "name": "openhypercore",
  "version": "0.1.2",
  "description": "Lightweight, GPU-free video composition + rendering engine: a JSON scene-graph IR, CanvasKit/Skia (wasm) or native (Rust + skia-safe) renderer, and an FFmpeg encoder — with a CLI for scripted/agent use.",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "license": "MIT",
  "author": "gongbin <blogcool@gmail.com>",
  "homepage": "https://github.com/gongbin/openHyperCore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gongbin/openHyperCore.git"
  },
  "bugs": {
    "url": "https://github.com/gongbin/openHyperCore/issues"
  },
  "keywords": [
    "video",
    "rendering",
    "compositing",
    "motion-graphics",
    "skia",
    "canvaskit",
    "ffmpeg",
    "remotion",
    "scene-graph",
    "server-side-rendering"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "openhyper": "./dist/packages/cli/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./renderer-skia": {
      "types": "./dist/packages/renderer-skia/src/index.d.ts",
      "import": "./dist/packages/renderer-skia/src/index.js"
    },
    "./renderer-skia/draw": {
      "types": "./dist/packages/renderer-skia/src/draw.d.ts",
      "import": "./dist/packages/renderer-skia/src/draw.js"
    },
    "./renderer-svg": {
      "types": "./dist/packages/renderer-svg/src/index.d.ts",
      "import": "./dist/packages/renderer-svg/src/index.js"
    },
    "./encoder-ffmpeg": {
      "types": "./dist/packages/encoder-ffmpeg/src/index.d.ts",
      "import": "./dist/packages/encoder-ffmpeg/src/index.js"
    },
    "./assets": {
      "types": "./dist/packages/assets/src/index.d.ts",
      "import": "./dist/packages/assets/src/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/packages/jsx-runtime/src/index.d.ts",
      "import": "./dist/packages/jsx-runtime/src/index.js"
    },
    "./cli": {
      "types": "./dist/packages/cli/src/index.d.ts",
      "import": "./dist/packages/cli/src/index.js"
    },
    "./server": {
      "types": "./dist/packages/server/src/index.d.ts",
      "import": "./dist/packages/server/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:native": "cargo build --manifest-path packages/renderer-native/Cargo.toml && node packages/renderer-native/scripts/copy-artifact.mjs",
    "build:native:release": "cargo build --release --manifest-path packages/renderer-native/Cargo.toml && NATIVE_PROFILE=release node packages/renderer-native/scripts/copy-artifact.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-strip-types --test packages/*/test/*.test.ts",
    "cli": "node --experimental-strip-types packages/cli/src/index.ts",
    "bench:fixtures": "node --experimental-strip-types packages/cli/src/index.ts bench-suite examples/bench/animated-workload.ts --static examples/bench/static-reuse.ts --out /tmp/openhyper-bench-suite.json --video-dir /tmp/openhyper-bench-suite",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "binaryName": "renderer-native",
    "packageName": "@openhypercore/native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "canvaskit-wasm": "^0.41.1"
  }
}

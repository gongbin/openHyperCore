{
  "name": "openhyper-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "openHyperEditor — a decoupled web tool that authors openhypercore IR, previews it with canvaskit-wasm (WYSIWYG), and renders the final MP4 via the openhypercore render service.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvaskit-wasm": "^0.41.1",
    "openhypercore": "^0.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
